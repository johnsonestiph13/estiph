# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# Database
MONGODB_URI=mongodb://localhost:27017/estif_home
MONGODB_URI_TEST=mongodb://localhost:27017/estif_home_test
MONGODB_URI_PROD=mongodb://production:27017/estif_home

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# MQTT Broker
MQTT_BROKER=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=estif_backend

# WebSocket
WS_PATH=/socket.io
WS_PING_TIMEOUT=60000
WS_PING_INTERVAL=25000

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@estif-home.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AI / ML
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
ENABLE_AI_PREDICTIONS=true

# Bluetooth
BLUETOOTH_ENABLED=true
BLUETOOTH_SCAN_INTERVAL=30000
BLUETOOTH_TIMEOUT=5000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_FILES=30
LOG_MAX_SIZE=20m

# Backup
BACKUP_ENABLED=true
BACKUP_PATH=./backups
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Monitoring
SENTRY_DSN=
DATADOG_API_KEY=
NEWRELIC_LICENSE_KEY=

# PWA
PWA_CACHE_NAME=estif-home-v3
PWA_OFFLINE_URL=/offline.html

# Third Party
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Emergency Contacts
EMERGENCY_PHONE=+251987713787
EMERGENCY_EMAIL=emergency@estif-home.com

# Features
ENABLE_2FA=true
ENABLE_VOICE_COMMANDS=true
ENABLE_BLUETOOTH_PROXIMITY=true
ENABLE_MULTI_HOME=true
ENABLE_OFFLINE_MODE=true