{
  "name": "estif-home-frontend",
  "version": "3.0.0",
  "description": "Enterprise Smart Home Frontend - PWA with Multi-user, Real-time Sync, Voice Control",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:prod": "vite build --mode production",
    "build:staging": "vite build --mode staging",
    "preview:prod": "vite preview --mode production",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,html}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "analyze": "vite build --mode production --analyze",
    "serve": "serve dist -s -l 5173",
    "deploy": "npm run build && npm run serve"
  },
  "dependencies": {
    "@capacitor/android": "^5.5.0",
    "@capacitor/core": "^5.5.0",
    "@capacitor/ios": "^5.5.0",
    "@capacitor/splash-screen": "^5.0.6",
    "@ionic/pwa-elements": "^3.2.2",
    "axios": "^1.6.0",
    "chart.js": "^4.4.0",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.0",
    "framer-motion": "^10.16.0",
    "idb": "^8.0.0",
    "qrcode": "^1.5.3",
    "qrcode.react": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^4.11.0",
    "react-qr-code": "^2.0.12",
    "react-router-dom": "^6.18.0",
    "recharts": "^2.9.0",
    "socket.io-client": "^4.6.0",
    "swiper": "^10.3.0",
    "uuid": "^9.0.0",
    "workbox-core": "^7.0.0",
    "workbox-expiration": "^7.0.0",
    "workbox-precaching": "^7.0.0",
    "workbox-routing": "^7.0.0",
    "workbox-strategies": "^7.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitejs/plugin-react-swc": "^3.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.32.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.6.0",
    "jest-environment-jsdom": "^29.6.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "sass": "^1.69.0",
    "tailwindcss": "^3.3.0",
    "vite": "^4.4.0",
    "vite-plugin-pwa": "^0.17.0",
    "vite-plugin-svgr": "^4.0.0",
    "vitest": "^0.34.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": ["<rootDir>/src/setupTests.js"],
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "identity-obj-proxy",
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/__mocks__/fileMock.js"
    },
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/**/*.test.{js,jsx}",
      "!src/index.js",
      "!src/serviceWorker.js"
    ]
  },
  "keywords": [
    "smart-home",
    "iot",
    "pwa",
    "home-automation",
    "esp32",
    "voice-control",
    "bluetooth",
    "real-time",
    "multi-user"
  ],
  "author": "Estifanos Yohannis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/johnsonestiph13/estiph.git"
  }
}